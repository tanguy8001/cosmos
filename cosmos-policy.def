# Singularity definition file for cosmos-policy
# Equivalent to docker/Dockerfile — adapted for HPC/Slurm use with Singularity.
# The Docker entrypoint user-mapping is omitted: Singularity runs as the host
# user automatically.

Bootstrap: docker
From: nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && \
        apt-get install -y --no-install-recommends \
            build-essential \
            cmake \
            curl \
            ffmpeg \
            git \
            git-lfs \
            gosu \
            libgl1 \
            libegl1-mesa-dev \
            libgl1-mesa-dri \
            libglib2.0-0 \
            sudo \
            tree \
            wget \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # Install uv 0.8.12
    # Equivalent of: COPY --from=ghcr.io/astral-sh/uv:0.8.12 /uv /uvx /usr/local/bin/
    mkdir -p /tmp/uv-install
    curl -fsSL https://github.com/astral-sh/uv/releases/download/0.8.12/uv-x86_64-unknown-linux-gnu.tar.gz \
        | tar -xz -C /tmp/uv-install
    install -m 755 $(find /tmp/uv-install -name "uv"  -type f) /usr/local/bin/uv
    install -m 755 $(find /tmp/uv-install -name "uvx" -type f) /usr/local/bin/uvx
    rm -rf /tmp/uv-install

    # Install just 1.42.4
    curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh \
        | bash -s -- --to /usr/local/bin --tag 1.42.4

%environment
    export DEBIAN_FRONTEND=noninteractive
    export SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
    export UV_LINK_MODE=copy

%runscript
    exec "$@"

%labels
    Source https://github.com/NVlabs/cosmos-policy
    BaseImage nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04
